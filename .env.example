MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/contacts?retryWrites=true&w=majority
PORT=3000
MONGODB_DB=contacts

# Replace <username>, <password>, and <cluster> with your Atlas values.
# Example:
# MONGODB_URI=mongodb+srv://myUser:mySecret@cluster0.mongodb.net/contacts?retryWrites=true&w=majority
